# ============================================================
# WishlistCart.com — Environment Variables
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to git
# ============================================================

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...your-anon-key
SUPABASE_SERVICE_ROLE_KEY=eyJ...your-service-role-key

# --- Database (Vercel Prisma Postgres + Accelerate) ---
# Runtime: Prisma Client uses Accelerate URL (connection pooling + caching)
DATABASE_URL="prisma+postgres://accelerate.prisma-data.net/?api_key=your-accelerate-api-key"
# Migrations: Prisma CLI uses direct postgres URL
DIRECT_URL="postgres://user:password@db.prisma.io:5432/postgres?sslmode=require"

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Stripe ---
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_MONTHLY_PRICE_ID=price_...
STRIPE_PRO_ANNUAL_PRICE_ID=price_...

# --- Resend (Email) ---
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@wishlistcart.com

# --- Inngest (Background Jobs) ---
INNGEST_EVENT_KEY=...
INNGEST_SIGNING_KEY=...
# Inngest webhook URL: https://yourapp.vercel.app/api/inngest

# --- Upstash Redis (Rate Limiting / Cache) ---
UPSTASH_REDIS_REST_URL=https://...upstash.io
UPSTASH_REDIS_REST_TOKEN=...

# --- Affiliate Networks ---
AMAZON_ASSOCIATE_TAG=wishlistcart-20
SHAREASALE_AFFILIATE_ID=
CJ_AFFILIATE_ID=

# --- Analytics & Monitoring ---
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
NEXT_PUBLIC_SENTRY_DSN=https://...sentry.io/...
SENTRY_ORG=your-sentry-org
SENTRY_PROJECT=wishlistcart
SENTRY_AUTH_TOKEN=sntrys_...
